# LexOps Environment Variables — copy to .env and fill in your values
# DO NOT commit .env to version control

# ── LLM ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
USE_OLLAMA=false

# ── Paths ────────────────────────────────────────────────────────────────────
DATA_PATH=./data/laws/
JUDGMENT_PATH=./data/judgments/
STORAGE_PATH=./data/storage/
CHROMA_PATH=./data/chroma_db/
DATABASE_URL=sqlite:///./lexops.db

# Observability 
PHOENIX_PORT=

#  Telegram \
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

#  Slack Alerts 
SLACK_WEBHOOK_URL=

#  Gmail Intake (optional) 
GMAIL_USER=
GMAIL_PASS=
